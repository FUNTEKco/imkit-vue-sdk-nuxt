{
  "name": "imkit-vue-sdk",
  "private": true,
  "version": "1.112.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/imkit-vue-sdk.umd.cjs",
  "module": "./dist/imkit-vue-sdk.js",
  "exports": {
    ".": {
      "import": "./dist/imkit-vue-sdk.js",
      "require": "./dist/imkit-vue-sdk.umd.cjs"
    },
    "./custom-element": {
      "types": "./dist/custom-element.d.ts",
      "import": "./dist/imkit-custom-element.js",
      "require": "./dist/imkit-custom-element.umd.cjs"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build --config vite.config.ts",
    "build:lib": "vue-tsc --noEmit && vite build --config vite-lib.config.ts && pnpm verify:esm-bundle",
    "build:lib-dev": "vue-tsc --noEmit && vite build --config vite-lib.config.ts && pnpm verify:esm-bundle && cp -R dist/ ../pinchat_web_v6/sdk/imkit-vue-sdk/dist && cp package.json ../pinchat_web_v6/sdk/imkit-vue-sdk/package.json",
    "build:custom-element": "vite build --config vite-custom-element.config.ts && cp src/custom-element.d.ts dist/custom-element.d.ts && rm -rf dist/sticker && cp -R public/sticker dist/sticker",
    "verify:esm-bundle": "node scripts/verify-esm-bundle.mjs",
    "verify:consumer-fixture": "node scripts/verify-consumer-fixture.mjs",
    "preview": "vite preview",
    "test": "vitest run --coverage && playwright test",
    "test:unit": "vitest run --coverage",
    "test:e2e": "playwright test",
    "update-snapshots": "find tests/e2e -path '*-snapshots/*-darwin.*' -o -path '*-snapshots/*-linux.*' -o -path '*-snapshots/*-win32.*' | xargs rm -f && playwright test --update-snapshots",
    "prepare": "is-ci || husky install",
    "upstream:merge": "./scripts/upstream-merge.sh",
    "project:init": "./scripts/project-init.sh",
    "generate:token": "./scripts/generate-token.sh",
    "lint": "eslint --max-warnings 0 src/ tests/",
    "lint:fix": "eslint --fix src/ tests/",
    "prettier": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "vue-tsc --noEmit",
    "check": "concurrently --group --kill-others-on-fail -n lint,format,types,unit,build -c blue,green,magenta,cyan,yellow \"pnpm lint\" \"pnpm format:check\" \"pnpm typecheck\" \"pnpm test:unit\" \"pnpm build && pnpm build:lib\" && pnpm test:e2e",
    "sync-lock": "npm install --legacy-peer-deps --package-lock-only"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "@rocicorp/lock": "^1.0.4",
    "@vueuse/components": "^14.2.1",
    "@vueuse/core": "^14.2.1",
    "autolinker": "github:imkit/Autolinker.js#0c4c8fd666c8322451095e92760c9c385efa0a26",
    "axios": "^1.15.0",
    "@vueform/toggle": "^2.1.4",
    "bowser": "^2.13.1",
    "browser-image-compression": "^2.0.2",
    "cheerio": "^1.2.0",
    "dayjs": "^1.11.20",
    "firebase": "^12.12.0",
    "get-blob-duration": "^1.2.0",
    "hash-wasm": "^4.12.0",
    "howler": "^2.2.4",
    "jose": "^6.2.2",
    "lucide-vue-next": "^1.0.0",
    "luxon": "^3.7.2",
    "markdown-it": "^14.1.1",
    "p-limit": "^7.3.0",
    "promise-coalesce": "^1.5.0",
    "quick-lru": "^7.3.0",
    "radix-vue": "^1.9.17",
    "recordrtc": "^5.6.2",
    "socket.io-client": "^4.8.3",
    "storage-available": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "textarea-caret": "^3.1.0",
    "throttle-debounce": "^5.0.2",
    "uuid": "^13.0.0",
    "validator": "^13.15.35",
    "video.js": "^8.23.7",
    "vue-dark-switch": "^1.0.6",
    "vue-final-modal": "^4.5.5",
    "vue-renderer-markdown": "0.0.63-beta.4",
    "vue3-emoji-picker": "^1.1.8",
    "vue3-google-map": "^0.27.1",
    "vue3-popper": "^1.5.0",
    "vue3-radial-progress": "^1.1.1",
    "vue3-touch-events": "^5.0.15",
    "vue3-virtual-scroll-list": "^0.2.1"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "vue-i18n": "^11.0.0",
    "vue-router": "^4.6.0 || ^5.0.0",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "10.0.1",
    "@playwright/test": "^1.59.1",
    "@rollup/plugin-dynamic-import-vars": "^2.1.5",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/eslint": "^9.6.1",
    "@types/howler": "^2.2.12",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.1",
    "@types/markdown-it": "^14.1.2",
    "@types/recordrtc": "^5.6.15",
    "@types/shuffle-array": "^1.0.5",
    "@types/throttle-debounce": "^5.0.2",
    "@types/validator": "^13.15.10",
    "@types/video.js": "^7.3.58",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "commitizen": "4.3.1",
    "concurrently": "^9.2.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "husky": "9.1.7",
    "is-ci": "^4.1.0",
    "lint-staged": "16.4.0",
    "postcss": "^8.5.9",
    "prettier": "^3.8.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sass-embedded": "^1.99.0",
    "semantic-release": "25.0.3",
    "shuffle-array": "^1.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vite-plugin-libcss": "^1.1.2",
    "vite-plugin-mkcert": "^2.0.0",
    "vitest": "^4.1.4",
    "vue-eslint-parser": "^10.4.0",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2",
    "vue-router": "^5.0.4",
    "vuex": "^4.1.0",
    "vue-tsc": "^3.2.6"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "engines": {
    "node": "^22.14.0 || >=24.10.0"
  },
  "lint-staged": {
    "{src,tests}/**/*.{js,ts,tsx,vue}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "packageManager": "pnpm@10.25.0"
}
